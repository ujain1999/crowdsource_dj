.audio-player {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  padding: 1.5rem;
  background-color: var(--bg-secondary-light);
  border-radius: 6px;
}

html.dark-mode .audio-player {
  background-color: var(--bg-secondary-dark);
}

.now-playing {
  display: flex;
  gap: 1rem;
  align-items: center;
}

.thumbnail {
  width: 80px;
  height: 80px;
  border-radius: 6px;
  object-fit: cover;
}

.song-info {
  flex: 1;
  min-width: 0;
}

.song-info h3 {
  margin: 0;
  font-size: 1.1rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.song-info p {
  margin: 0.25rem 0 0 0;
  font-size: 0.9rem;
  opacity: 0.7;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.no-song {
  flex: 1;
  text-align: center;
  opacity: 0.5;
  padding: 1rem;
}

.player-controls {
  display: flex;
  justify-content: center;
  gap: 1rem;
}

.play-pause,
.prev-btn,
.next-btn {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background-color: var(--accent);
  color: white;
  font-size: 1.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.play-pause:hover,
.prev-btn:hover:not(:disabled),
.next-btn:hover:not(:disabled) {
  background-color: var(--accent-hover);
  transform: scale(1.1);
}

.prev-btn:disabled,
.next-btn:disabled {
  opacity: 0.3;
  cursor: not-allowed;
}

.progress {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.time {
  font-size: 0.85rem;
  min-width: 40px;
  text-align: center;
}

.progress-bar {
  flex: 1;
  cursor: pointer;
  height: 4px;
  border-radius: 2px;
  -webkit-appearance: none;
  appearance: none;
  background: var(--border-light);
}

html.dark-mode .progress-bar {
  background: var(--border-dark);
}

.progress-bar::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--accent);
  cursor: pointer;
}

.progress-bar::-moz-range-thumb {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--accent);
  cursor: pointer;
  border: none;
}
