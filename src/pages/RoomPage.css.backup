.room-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: var(--bg-light);
  color: var(--text-light);
}

html.dark-mode .room-page {
  background-color: var(--bg-dark);
  color: var(--text-dark);
}

.room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem;
  border-bottom: 1px solid var(--border-light);
  background-color: var(--bg-secondary-light);
}

html.dark-mode .room-header {
  border-bottom-color: var(--border-dark);
  background-color: var(--bg-secondary-dark);
}

.header-left h1 {
  margin: 0;
  font-size: 1.5rem;
}

.room-code {
  margin: 0;
  font-size: 0.9rem;
  opacity: 0.7;
}

.header-right {
  display: flex;
  gap: 1rem;
  align-items: center;
}

.leave-btn {
  padding: 0.5rem 1.5rem;
  background-color: #dc3545;
  color: white;
  border-radius: 6px;
  font-weight: 600;
}

.leave-btn:hover {
  background-color: #c82333;
}

.room-layout {
  display: flex;
  flex: 1;
  overflow: hidden;
}

.main-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  padding: 1.5rem;
}

.player-section {
  margin: 1.5rem 0;
}

.sidebar {
  width: 320px;
  border-left: 1px solid var(--border-light);
  background-color: var(--bg-secondary-light);
  overflow-y: auto;
  padding: 1.5rem;
}

html.dark-mode .sidebar {
  border-left-color: var(--border-dark);
  background-color: var(--bg-secondary-dark);
}

.loading,
.error {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  font-size: 1.2rem;
}

.error {
  color: #dc3545;
}

@media (max-width: 1024px) {
  .room-layout {
    flex-direction: column;
  }

  .sidebar {
    width: 100%;
    border-left: none;
    border-top: 1px solid var(--border-light);
    max-height: 300px;
  }

  html.dark-mode .sidebar {
    border-top-color: var(--border-dark);
  }
}
